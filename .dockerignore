# Don't ship internal docs, secrets, build caches into the image
.git
.gitignore
.githooks
.venv
venv
__pycache__
*.pyc
.pytest_cache
.mypy_cache
.ruff_cache
.DS_Store
*.swp
*.bak
*.bak.*

# Internal-only files (.gitignore would already exclude them from a fresh clone,
# but a working dev tree has them, so list explicitly for docker context)
CONSTRAINTS.md
SESSION_HANDOFF.md
NOTES.md
TODO.md
dashboard.html
.claude

# Test data / config that mustn't bake into the image
*.db
*.db-journal
*.db-wal
*.db-shm
config.yaml
.env
.env.*
*.key
*.pem
*.crt
secrets/
